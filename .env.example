# PostgreSQL connection. Either set DATABASE_URL...
DATABASE_URL=postgres://redemption:redemption@localhost:5432/redemption

# ...or the individual PG* vars (used when DATABASE_URL is unset):
# PGHOST=localhost
# PGPORT=5432
# PGUSER=redemption
# PGPASSWORD=redemption
# PGDATABASE=redemption

# API port (optional, defaults to 3000)
# PORT=3000
